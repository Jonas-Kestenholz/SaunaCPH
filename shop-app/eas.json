{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      }
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "bundleIdentifier": "com.shopsauna.SAUNA",
        "ascAppId": "DIN_ASC_APP_ID",
        "ascApiKeyPath": "./AuthKey.p8",
        "ascApiKeyIssuerId": "${ASC_ISSUER_ID}",
        "ascApiKeyId": "${ASC_KEY_ID}"
      }
    }
  }
}